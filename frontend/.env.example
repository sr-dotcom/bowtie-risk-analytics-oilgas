# Frontend environment variables
#
# NEXT_PUBLIC_* values are baked into the client bundle at `next build` time,
# not at runtime. For production Docker builds, set these as build-args or
# in the build environment BEFORE running `next build`.
#
# Local dev default:  http://localhost:8000
# Production:         https://api.bowtie.gnsr.dev
#
# This var is consumed by next.config.ts rewrites:
#   /api/:path*  →  ${NEXT_PUBLIC_API_URL}/:path*
NEXT_PUBLIC_API_URL=http://localhost:8000

# Set to "false" to disable the experimental narrative synthesis feature.
NEXT_PUBLIC_ENABLE_T2B_SYNTHESIS=false
