# Copy to .env and fill in your keys (never commit .env)
# Used by: uvicorn API server and Docker Compose api service

# Required — default provider for structured extraction and evidence narratives
ANTHROPIC_API_KEY=your-key-here

# Optional — only needed for benchmarking / fallback providers
OPENAI_API_KEY=
GEMINI_API_KEY=

# Security — API key for endpoint authentication (leave empty to disable auth)
BOWTIE_API_KEY=

# CORS — comma-separated allowed origins
# Default behavior: src/api/main.py uses "https://bowtie.gnsr.dev,http://localhost:3000"
# when CORS_ALLOWED_ORIGINS is unset (legacy hosted-demo default; covered by
# tests/test_api.py::test_cors_preflight_prod_origin). Override here for your
# deployment by setting an explicit comma-separated list.
CORS_ALLOWED_ORIGINS=http://localhost:3000

# Set to "true" to enable /docs, /redoc, /openapi.json (disabled by default)
BOWTIE_ENABLE_DOCS=
