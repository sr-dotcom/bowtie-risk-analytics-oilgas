# Copy to .env and fill in your keys (never commit .env)
# Used by: uvicorn API server and Docker Compose api service

# Required — default provider for structured extraction and evidence narratives
ANTHROPIC_API_KEY=your-key-here

# Optional — only needed for benchmarking / fallback providers
OPENAI_API_KEY=
GEMINI_API_KEY=

# Security — API key for endpoint authentication (leave empty to disable auth)
BOWTIE_API_KEY=

# CORS — comma-separated allowed origins (default: http://localhost:3000)
# For production deployment, set this env var explicitly. Example for the
# self-hosted demo: CORS_ALLOWED_ORIGINS=http://localhost:3000,https://bowtie.gnsr.dev
CORS_ALLOWED_ORIGINS=http://localhost:3000

# Set to "true" to enable /docs, /redoc, /openapi.json (disabled by default)
BOWTIE_ENABLE_DOCS=
