  "event": {
    "top_event": "Loss of Containment",
    "incident_type": "Fire",
    "costs": "100000",
    "actions_taken": [
      "Platform emergency shut down device activated",
      "Fire extinguished using two 150 pound and two 30-pound fire extinguishers",
      "Fire extinguished in ten minutes",
      "Glycol Reboiler Dehydration unit removed and transported to Universal Equipment Company for inspection",
      "Root cause analysis conducted with third-party consultant GIR Solutions"
    ],
    "summary": "On January 5, 2023, at 1730 hours, a fire occurred at High Island 547 B platform involving the Glycol Reboiler Dehydration system. The still column vent pipe became plugged, resulting in pressure build up until it ruptured. The rupture caused glycol to spray which contacted the reboiler and exhaust stack (operating at 750-800°F), igniting the glycol mixture. Platform operators activated emergency shutdown and extinguished the fire in ten minutes using fire extinguishers. No injuries or pollution occurred. Fire damage was limited to the Glycol Reboiler and Dehydration unit, totaling over $100,000.",
    "recommendations": [
      "Develop a servicing plan to inspect the Still Column Vent piping",
      "Implement a still column replacement campaign to coincide with the 5-year fire tube inspection requirement",
      "Perform a condition assessment of all still columns across the gulf by the end of 1st quarter FY 23"
    ],
    "key_phrases": [
      "still column vent pipe became plugged",
      "pressure build up in the column vent pipe until it ruptured",
      "glycol to spray which contacted the reboiler and exhaust stack",
      "operating temperature of 750 to 800 degrees Fahrenheit",
      "ignited the glycol mixture",
      "Build up and clogging of the Still Column Vent pipe"
    ]
  },
