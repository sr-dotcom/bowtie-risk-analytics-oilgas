  "event": {
    "top_event": "Loss of Containment of Heavy Equipment",
    "incident_type": "Personnel Injury - Struck By",
    "costs": null,
    "actions_taken": [
      "Sling attached to wellhead and crane used to roll wellhead off injured party's leg",
      "IP moved onto stokes litter and relocated to galley",
      "Medevac helicopter requested",
      "Boot and sock cut off, gauze and leg brace applied",
      "Nearby platform medic contacted for treatment instructions",
      "IP lifted to platform helideck using lift boat crane",
      "IP evacuated to hospital via medevac helicopter at 0530 hours",
      "G-110 Incident of Non-Compliance issued on 11 October 2023",
      "Corrective action: keep scrap basket onboard to secure wellheads"
    ],
    "summary": "On 21 September 2023 at approximately 0130 hours, a night shift Supervisor sustained a compound fracture with exposed bone on his lower left shin when an unsecured 8000-pound wellhead rolled onto his leg after he sat on it and stood up. The wellhead had been removed from Well #13 during day shift operations and laid on its side on the deck of the Lift Boat Man-O-War without proper securing. Personnel had attempted to check stability by hand before removing rigging, but this was insufficient. The wellhead was in an unstable position and may have shifted due to lift boat movements from weather and crane activity. The injured party was evacuated by medevac helicopter for medical treatment, resulting in days away from work.",
    "recommendations": [
      "Keep scrap basket onboard to contain and secure wellheads after removal",
      "Ensure adequate hazard analysis and written job procedures for wellhead removal operations",
      "Provide adequate tools and equipment for securing loads on deck",
      "Improve JSA process to identify job steps, hazards, and mitigation measures"
    ],
    "key_phrases": [
      "wellhead rolled onto leg",
      "unsecured on deck",
      "compound fracture with exposed bone",
      "8000-pound wellhead",
      "unstable position",
      "checked stability by hand",
      "rigging removed",
      "lift boat movements",
      "no scrap basket available",
      "failed to secure and anchor"
    ]
