  "event": {
    "top_event": "Hand Caught Between C-Plates",
    "incident_type": "Personnel Injury - Caught Between",
    "costs": null,
    "actions_taken": [
      "Job stopped and worksite secured",
      "IP evaluated by rig medic",
      "IP evacuated to onshore facility",
      "IP received 14 stitches and treatment for broken finger",
      "IP released to light duty on 4/22/24",
      "IP released to full duty on 5/22/24"
    ],
    "summary": "On April 22, 2024, a hand injury occurred on the drillship Noble Stanley Lafosse during wireline completion operations at Green Canyon Block 389. The injured person (IP) was assisting the wireline helper disconnect wireline tools when his right hand was caught between the upper C-plate with tools weighing 175 lbs and lower C-plate. The helper had raised the tool string approximately 4 inches above the bottom C-plate. The IP placed his right hand under the upper C-plate to stabilize the tool string. When the helper released the tools, they fell 4 inches, smashing the IP's right hand between the C-plates, causing lacerations to the right hand ring and middle fingertips and a broken finger tip. The IP required evacuation and 14 stitches. Investigation revealed the helper lacked deepwater experience, the IP was not properly trained on wireline tools, the JSEA was inadequate, communication was poor, and Stop Work Authority was not used.",
    "recommendations": [
      "BSEE Houma District has no recommendations for the Office of Incident Investigations at this time"
    ],
    "key_phrases": [
      "hand caught between C-plates",
      "wireline tools weighing 175 lbs",
      "tools fell 4 inches",
      "lack of deepwater experience",
      "not properly trained on wireline tools",
      "inadequate communication",
      "Stop Work Authority not used",
      "failed to identify pinch point hazard",
      "lack of situational awareness"
    ]
  },
