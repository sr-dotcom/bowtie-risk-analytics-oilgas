  "event": {
    "top_event": "Loss of Containment",
    "incident_type": "Equipment Failure with Fire",
    "costs": ">$25,000",
    "actions_taken": [
      "Night operator activated fire alarm and ESD",
      "Personnel alerted door-to-door",
      "Fire extinguished using firewater hose and 2 (30 lb.) dry chemical extinguishers",
      "Rotating Equipment Specialist investigated on January 17, 2024",
      "Instrumentation and Electrical Contractor tested vibration switches on January 18, 2024",
      "In-line desiccant dryer ordered for pneumatic supply inlets"
    ],
    "summary": "On January 16, 2024, at approximately 0252 hours, the C1 compressor experienced a piston failure at Arena Offshore SM 128 B Facility. The piston rod penetrated the housing, releasing gas that ignited. The night operator discovered the fire, activated the fire alarm and ESD, and alerted personnel. Operators extinguished the fire using a firewater hose and dry chemical extinguishers. Investigation revealed the piston detached from the piston rod due to a loosened nut, causing connecting rod bolts to break and the piston rod to contact the cylinder head. The vibration switch tripped but failed to shut down the compressor due to frozen moisture in the output line caused by 17°F temperatures. No injuries occurred. The compressor is scheduled for rebuild.",
    "recommendations": [
      "Install in-line desiccant dryer to pneumatic supply inlets of compressor control panel to prevent condensation formation in tubing"
    ],
    "key_phrases": [
      "piston failure",
      "vibration switch tripped but failed to initiate shut down",
      "frozen moisture in output line",
      "scarring on piston indicating poor maintenance",
      "piston rod nut loosening",
      "connecting rod bolts broke",
      "gas ignited through vent system"
    ]
  },
