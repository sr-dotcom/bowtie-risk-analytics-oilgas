  "event": {
    "top_event": "Loss of Containment",
    "incident_type": "Explosion",
    "costs": "50000",
    "actions_taken": [
      "IP immediately shut valve to jet fuel pump",
      "IP dove to ground and crawled to exit area",
      "IP reported to medic for evaluation",
      "Murphy issued companywide safety alert",
      "Murphy sent bottle to third party for metallurgical analysis",
      "Murphy began drafting new policies and procedures"
    ],
    "summary": "On April 28, 2025, a nitrogen bottle exploded on the BW Pioneer FPSO during refilling operations. The bottle, rated for 2,400 psi, was mistakenly filled to over 5,000 psi because it was misidentified as a 6,000 psi bottle. The incorrect 9,000 psi relief valve installed during maintenance in December 2023 failed to prevent overpressurization. The explosion caused structural damage to the bottle rack, damaged nearby equipment including a diesel tank, and injured a crane operator with shrapnel, causing hearing impairment and minor bruises.",
    "recommendations": [
      "Install correct pressure relief valves rated for cylinder design pressure",
      "Develop formal written procedures for nitrogen bottle filling operations",
      "Implement proper training program on cylinder identification and pressure ratings",
      "Clearly identify and segregate bottles by pressure rating",
      "Update JSA to specify target pressure and identify overpressurization hazards",
      "Establish routine inspection and maintenance program for pressure vessels"
    ],
    "key_phrases": [
      "overpressurization",
      "incorrect relief valve",
      "inadequate training",
      "no formal procedure",
      "cylinder misidentification",
      "ductile overload failure"
    ]
  },
